# Compiled Python files
__pycache__/
*.pyc

# Distribution / packaging
dist/
build/
*.egg-info/

# Local development settings
*.env
*.env.local
*.venv
venv/
ENV/

# Logs and databases
*.log
*.sqlite3

# Jupyter Notebook specific
.ipynb_checkpoints/

# System generated files
.DS_Store
Thumbs.db

# Cache files
*.cache/
.cache/

# -----------------------------
# Aetherion
# -----------------------------

data/*
# Explicit listing for grep/audit — the runtime game DB grew to 22MB
# and was tracked historically; the `data/*` glob above already covers
# it, this line just makes the intent obvious.
data/game.sqlite

# pytest-cov runtime artifact — mutates every test run, no business in
# version control. Was tracked historically; untracked alongside
# data/game.sqlite for the same reason.
.coverage

libs/*
site-packages/*

# vcpkg (manifest install / local caches — keep vcpkg.json + vcpkg-lock.json committed)
.vcpkg/
.vcpkg_cache/
.vcpkg_installed/
.vcpkg-binary-cache/

build-tests/*
tmp/*
html/*
xml/*
latex

# Water-physics debug log (only emitted when WaterDebugLog is enabled)
water_debug.jsonl

# ----------------------
#  Aetherion Webclient
# ----------------------

webclient/dist/
webclient/node_modules/
webclient/tests/fixtures/

# ------------
#  Docs
# ------------

# Ignore the Sphinx build directory
docs/_build/
# Ignore temporary files
docs/_static/.doctrees/
docs/_static/.buildinfo
# Ignore Python cache files
docs/__pycache__/
docs/**/*.pyc
# Ignore editor backups (e.g., vim, emacs)
docs/*~
docs/#*#
docs/.#*
# Ignore logs and debug files
docs/*.log
docs/*.tmp

docs/html
docs/latex

# ------------
#  .claude
# ------------

.claude/docs/*

# Local-only rule overrides — for redirecting flows to private repos
# or per-user knobs that should not be shared. Public rules in
# .claude/rules/*.md still apply; *.local.md files take precedence.
.claude/rules/*.local.md
